version: '3.9' frontend:
    build: ./clinic-frontend
    ports:
      - "3000:3000"
    volumes:
      - ./clinic-frontend:/app
      - /app/node_modules
    environment:
      - CHOKIDAR_USEPOLLING=true
      - REACT_APP_API_URL=http://localhost:5000
    depends_on:
      - backend

services:
  mysql:
    image: mysql:8.0
    container_name: clinic-mysql
    environment:
      MYSQL_ROOT_PASSWORD: rootpass
      MYSQL_DATABASE: clinic
      MYSQL_USER: clinic
      MYSQL_PASSWORD: clinicpass
    ports:
      - "3306:3306"
    volumes:
      - mysql-data:/var/lib/mysql
    command: --default-authentication-plugin=mysql_native_password

  keycloak:
    image: quay.io/keycloak/keycloak:21.1.1
    container_name: clinic-keycloak
    environment:
 frontend:
    build: ./clinic-frontend
    ports:
      - "3000:3000"
    volumes:
      - ./clinic-frontend:/app
      - /app/node_modules
    environment:
      - CHOKIDAR_USEPOLLING=true
      - REACT_APP_API_URL=http://localhost:5000
    depends_on:
      - backend      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: admin
    command: start-dev
    ports:
      - "8081:8080"
    depends_on:
      - mysql

  backend:
    build:
      context: .
 frontend:
    build: ./clinic-frontend
    ports:
      - "3000:3000"
    volumes:
      - ./clinic-frontend:/app
      - /app/node_modules
    environment:
      - CHOKIDAR_USEPOLLING=true
      - REACT_APP_API_URL=http://localhost:5000
    depends_on:
      - backend      dockerfile: clinic-backend/Dockerfile
    container_name: clinic-backend
    ports:
      - "8080:8080"
    depends_on:
      - mysql
      - keycloak
    environment:
      SPRING_DATASOURCE_URL: jdbc:mysql://mysql:3306/clinic?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
      SPRING_DATASOURCE_USERNAME: clinic
      SPRING_DATASOURCE_PASSWORD: clinicpass
      SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI: http://keycloak:8080/realms/clinic
      SPRING_FLYWAY_ENABLED: "false"
    
volumes:
  mysql-data:
